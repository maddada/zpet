    },
    {
      "key": "Right",
      "modifiers": ["ctrl"],
      "action": "prompt_move_word_right",
      "args": {},
      "when": "prompt"
    },
    {
      "comment": "Ctrl+K -> Delete to prompt end (Unix readline)",
      "key": "k",
      "modifiers": ["ctrl"],
      "action": "prompt_delete_to_line_end",
      "args": {},
